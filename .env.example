# ============================================================
#  DORAEMI BOT — cấu hình môi trường
#  Copy file này thành .env rồi điền giá trị thật.
# ============================================================

# ---------- CHUNG ----------
# Khóa bí mật để server <-> local-runner xác thực với nhau.
# Đặt 1 chuỗi ngẫu nhiên dài, GIỐNG NHAU ở cả 2 nơi.
API_KEY=doi-thanh-chuoi-ngau-nhien-dai
# Bắt buộc phải có API_KEY mới cho chạy (fail-closed). Tự BẬT khi NODE_ENV=production.
# Đặt REQUIRE_API_KEY=true để ép cả khi không phải production. Dev để trống = vẫn chạy được.
REQUIRE_API_KEY=

# ---------- SERVER (chạy trên ai.basso.vn hoặc local) ----------
# Nền tảng host (ai.basso.vn) thường tự cấp cổng qua biến PORT — server ưu tiên PORT
# nếu có, nếu không mới dùng SERVER_PORT dưới đây, cuối cùng mặc định 8080.
SERVER_PORT=8080

# --- Lưu trữ DỮ LIỆU BỀN (SQLite: Lịch sử báo + khóa chống gửi trùng) ---
# Container trên cloud là EPHEMERAL — restart là mất. Trỏ DB vào ổ/volume BỀN:
#   - DATA_DIR : thư mục chứa data (db sẽ là <DATA_DIR>/doraemi.sqlite). Vd /data hoặc /mnt/disk.
#   - DB_PATH  : (ưu tiên) đường dẫn FILE db đầy đủ. Vd /data/doraemi.sqlite.
# Để trống cả hai = dùng ./data trong thư mục app (CHỈ an toàn khi ./data nằm trên volume bền).
DATA_DIR=
DB_PATH=

# --- Đăng nhập do gateway ai.basso.vn lo (đứng trước app, mỗi nhân viên 1 tài khoản) ---
# App KHÔNG tự xác thực. Để GHI LẠI "ai gửi tin" vào Lịch sử báo, gateway forward danh tính
# nhân viên qua header — app thử lần lượt các header dưới, lấy giá trị đầu tiên có.
# Để trống = dùng mặc định (x-user-email,x-forwarded-email,x-forwarded-user,...).
AUTH_USER_HEADER=
# Siết CORS: liệt kê origin được phép (cách nhau dấu phẩy), vd https://ai.basso.vn
# Để trống = mở cho mọi origin (phù hợp khi gateway là lối vào duy nhất).
CORS_ORIGIN=
# Secret dùng chung gateway↔app: nếu đặt, mọi /api/* (trừ health/register-local/webhook) phải
# kèm header X-Gateway-Secret khớp -> chặn gọi thẳng app, giả mạo danh tính NV. Cấu hình gateway
# ai.basso.vn gắn header này khi forward. Để trống = bỏ qua (như cũ).
GATEWAY_SECRET=
# Allowlist host được phép đăng ký qua /api/register-local (cách nhau dấu phẩy, hỗ trợ *.domain).
# Vd: *.trycloudflare.com,localhost  — giảm rủi ro SSRF. Để trống = cho tất cả (như cũ).
REGISTER_ALLOWED_HOSTS=

# URL của local-runner mà server sẽ forward lệnh automation tới.
# LƯU Ý: nếu chạy `start.js` (launcher kiểu Xeko) thì runner TỰ đăng ký URL lên server,
# nên KHÔNG cần điền dòng này ở server nữa. Dòng này chỉ là fallback khi chưa có đăng ký
# (ví dụ chạy chung máy): http://localhost:8090. Khi máy local sau NAT thì dùng tunnel.
PLAYWRIGHT_LOCAL_URL=http://localhost:8090

# ---------- API WEBSITE BASSO (Partner API) ----------
# Để trống BASE_URL => server dùng dữ liệu MOCK trong server/mock/orders.json
# Ví dụ: https://api.basso.vn  (Basso cung cấp)
BASSO_API_BASE_URL=
# API key đối tác, gửi trong header X-Partner-Api-Key (mọi request)
BASSO_API_KEY=
# Tài khoản để login lấy access_token (POST /partner/login)
BASSO_EMAIL=
BASSO_PASS=
# Bật/tắt mock thủ công: true | false. Mặc định auto (mock khi chưa có BASE_URL)
USE_MOCK=
# Sau khi gửi Zalo thành công, tự cập nhật trạng thái 'Đã báo hàng' (notified_arrival) ngược về web
AUTO_UPDATE_STATUS=true
# Timeout (ms) cho mỗi request tới Basso — tránh treo "Đang tải..." khi upstream chậm. 0 = tắt
BASSO_TIMEOUT_MS=25000
# TTL (ms) cache danh sách hàng về trong RAM — đỡ gọi lại Basso mỗi lần auto-sync/đổi tab. 0 = tắt
BASSO_LIST_CACHE_TTL_MS=30000
# Cửa sổ ngày MẶC ĐỊNH của dashboard: chỉ kéo đơn trong N ngày gần đây thay vì all-time
# -> giảm mạnh lag khi tải (Basso quét ít trang hơn). 0 = mặc định all-time. Người dùng vẫn
# bấm "Tất cả (mọi ngày)" trong Bộ lọc để xem hết. Auto-notify/Báo hàng loạt KHÔNG bị giới
# hạn này (luôn quét all-time để không sót đơn cũ). Đổi số này thì đổi luôn DEFAULT_DAYS ở
# server/public/js/dashboard.js cho khớp cache preload.
BASSO_DEFAULT_DAYS=30
# Chu kỳ (ms) NẠP SẴN khung nhìn mặc định của dashboard vào cache RAM ở nền -> người mở
# dashboard không phải đợi Basso (giữ cache luôn ấm, kể cả sau khi server khởi động lại).
# 0 = tắt; nếu >0 thì tối thiểu 15000. Mặc định 60000 = 1 phút. Tự tắt khi MOCK hoặc cache TTL=0.
BASSO_PRELOAD_INTERVAL_MS=60000
# Bật để in thời gian từng call Basso ([basso] getArrivedVnList 2380ms) — chẩn đoán chậm do mạng hay do Basso
BASSO_LOG_TIMING=false

# ---------- TÀI KHOẢN ZALO THEO NHÂN VIÊN (tùy chọn) ----------
# Ánh xạ nhân viên -> tên tài khoản Zalo (đúng TÊN hiện trong dropdown chọn account ở
# zalo.salework.net). Mỗi đơn sẽ tự gửi bằng Zalo của nhân viên phụ trách đơn đó (cả báo
# tay lẫn tự động). Nhân viên KHÔNG có trong map -> dùng account mặc định
# (AUTO_NOTIFY_ACCOUNT cho tự động, DEFAULT_ZALO_ACCOUNT cho báo tay).
# JSON: key = user_id NV (ưu tiên, là số trong tab nhân viên) HOẶC tên nhân viên; value = tên Zalo.
# Ví dụ: {"18":"Zalo Linh","25":"Zalo Hà","Nguyễn Văn A":"Zalo A"}
ZALO_ACCOUNT_MAP=

# ---------- TỰ ĐỘNG BÁO HÀNG (auto-notify) ----------
# true = server tự quét đơn "Chưa báo" (đã về kho) và tự gửi tin, không cần bấm tay.
# Có thể bật/tắt ngay trên dashboard (badge "Tự động").
AUTO_NOTIFY=false
# Chu kỳ quét (ms). Mặc định 60000 = 1 phút. Tối thiểu 10000.
# Muốn gần tức-thì hơn nữa: bật webhook (AUTO_NOTIFY_WEBHOOK_SECRET) để Basso gọi sang khi có hàng về.
AUTO_NOTIFY_INTERVAL_MS=60000
# Profile Salework/Zalo dùng để gửi tự động (khớp profile đã đăng nhập ở local-runner)
AUTO_NOTIFY_PROFILE=default
# (Tùy chọn) tên account Zalo cần chọn trước khi gửi (khi 1 login quản nhiều account)
AUTO_NOTIFY_ACCOUNT=
# Bot gửi xong có đẩy trạng thái "Đã báo hàng" về web Basso không?
# true (mặc định) = đồng bộ trạng thái về Basso như báo tay (theo AUTO_UPDATE_STATUS).
# Đặt false nếu muốn bot CHỈ đánh dấu trong mi (badge "🤖 Bot đã gửi"), không động vào web.
AUTO_NOTIFY_UPDATE_WEB=true
# Số lần thử lại tối đa cho 1 đơn nếu gửi lỗi (tránh spam khi local-runner offline)
AUTO_NOTIFY_MAX_RETRIES=3
# (Tùy chọn) bí mật bảo vệ webhook POST /api/webhook/arrived. Để trống = không kiểm tra.
# Website Basso gọi sang kèm header x-webhook-secret để trigger gửi NGAY khi có hàng về.
AUTO_NOTIFY_WEBHOOK_SECRET=
# CHỈ tự báo đơn về TỪ khi account được bật "Tự động báo" trở đi (bỏ qua đơn tồn đọng về
# trước đó) -> tránh nhắn trùng loạt khách cũ khi bật lại auto cho 1 nhân viên. Mặc định true.
# Đặt false để bot gửi cả tồn đọng như trước. (Chỉ áp dụng account khớp NV — Hướng B.)
AUTO_NOTIFY_ONLY_NEW=true
# true = CHỈ tự gửi đơn khớp đúng 1 tài khoản Zalo đang BẬT auto; đơn không khớp account nào
# (rơi về mặc định) hoặc account tắt auto -> bỏ qua. Dùng cô lập test về 1 NV. Mặc định false.
AUTO_NOTIFY_REQUIRE_ACCOUNT=false
# GIỜ GỬI CỐ ĐỊNH (HH:MM, 24h). Khi có giá trị: bot KHÔNG gửi ngay lúc hàng về — cả ngày gom
# lại, tới đúng giờ này mới quét & gửi 1 lượt cho mọi đơn "Chưa báo" đã có nội dung (webhook
# chỉ để cập nhật). Để TRỐNG = gửi ngay theo poller như cũ. Admin đổi trên trang Cài đặt sẽ
# GHI ĐÈ giá trị này (lưu trong DB) và áp dụng ngay không cần restart. Mặc định 17:00.
AUTO_NOTIFY_SCHEDULE_TIME=17:00
# Múi giờ hiểu AUTO_NOTIFY_SCHEDULE_TIME (IANA tz). Mặc định giờ Việt Nam — server chạy UTC vẫn
# gửi đúng 17h theo giờ VN.
AUTO_NOTIFY_TZ=Asia/Ho_Chi_Minh
# Chu kỳ (ms) kiểm tra đồng hồ ở chế độ hẹn giờ (chỉ so giờ, rẻ). Mặc định 60000 (60s).
AUTO_NOTIFY_SCHEDULE_CHECK_MS=60000
# NHẮC SOẠN ND trước giờ gửi bao nhiêu PHÚT: trước giờ hẹn, bot tự quét (đọc tươi từ Basso) và
# cảnh báo số đơn "Chưa báo" còn THIẾU nội dung báo hàng để NV kịp soạn nốt. 0 = tắt nhắc.
# Mặc định 30 phút. Admin đổi trên trang Cài đặt sẽ ghi đè (lưu DB) và áp dụng ngay.
AUTO_NOTIFY_PRECHECK_MINUTES=30
# NHẮC RA ZALO (nội bộ): tới giờ nhắc và sau khi gửi xong, tự nhắn 1 tin Zalo cho người trực
# để biết mà không cần mở mi. Gửi bằng account Zalo đã đăng nhập trên runner. Tất cả chỉnh được
# trên trang Cài đặt (lưu DB, ghi đè các biến này). Mặc định tắt.
AUTO_NOTIFY_ALERT=false
AUTO_NOTIFY_ALERT_ACCOUNT=          # tên account Zalo gửi (đúng tên dropdown, vd: Bụt Ai)
AUTO_NOTIFY_ALERT_PHONE=           # SĐT nhận nhắc (của người trực)
AUTO_NOTIFY_ALERT_NAME=Admin       # tên hiển thị người nhận

# ---------- LOCAL RUNNER (chạy trên máy Windows có Chrome) ----------
LOCAL_PORT=8090

# ----- Tự đăng ký URL lên cloud (Xeko pattern) — dùng khi chạy `npm run runner` (start.js) -----
# URL bot trên cloud ai.basso.vn (nền tảng cấp khi triển khai), ví dụ:
# https://ai.basso.vn/b/9cdc3e8d6a564b5e . runner sẽ POST /api/register-local tới đây.
# Để trống = không tự đăng ký (server phải tự đặt PLAYWRIGHT_LOCAL_URL).
REMOTE_BOT_URL=
# URL công khai của runner để khai báo (tunnel ngrok/cloudflared). Để trống thì start.js
# dùng PLAYWRIGHT_LOCAL_URL (nếu không phải localhost) hoặc tự dò IP public + LOCAL_PORT.
PLAYWRIGHT_PUBLIC_URL=
# Chu kỳ heartbeat đăng ký lại (ms). Mặc định 30000 = 30s (cloud lưu URL trong RAM).
REGISTER_INTERVAL_MS=30000
# Mở cửa sổ browser để theo dõi/đăng nhập lần đầu: false = hiện cửa sổ
HEADLESS=false
# Làm chậm MỖI thao tác (ms) — chỉ để dễ nhìn khi debug. Chạy thật nên để 0 cho nhanh.
SLOW_MO=0
# Gửi xong thì đóng trình duyệt (giải phóng tài nguyên). Để false nếu muốn giữ trình duyệt
# sống giữa các lần gửi cho nhanh hơn khi gửi hàng loạt.
CLOSE_AFTER_SEND=true
# URL giao diện quản lý Zalo (nơi gửi tin). Mặc định Zalo Basso (zalo.basso.vn, Vuetify).
SALEWORK_URL=https://zalo.basso.vn
# Trang chat (có dropdown chọn account + danh sách hội thoại). Để trống = suy từ SALEWORK_URL + /chat.
SALEWORK_CHAT_URL=
# Khi 1 login quản lý NHIỀU tài khoản Zalo: điền TÊN account cần chọn trước khi gửi.
# Để trống = dùng tài khoản đang active. Phải khớp tên trong dropdown chọn Zalo.
DEFAULT_ZALO_ACCOUNT=
# URL trang đăng nhập (nếu khác trang chat). Để trống = dùng SALEWORK_URL
SALEWORK_LOGIN_URL=https://zalo.basso.vn

# ---------- FACEBOOK (báo hàng qua Messenger cho khách không dùng Zalo) ----------
# Login giống Xeko: mở facebook.com bằng profile riêng (fb-<key>), đăng nhập tay 1 lần, lưu session.
# Khách/nhân viên cần báo qua FB được chỉ định trên UI (Cài đặt → Báo qua Facebook), không qua .env.
# Trang mở khi ĐĂNG NHẬP Facebook
FACEBOOK_LOGIN_URL=https://www.facebook.com/
# Trang mở khi KIỂM TRA đăng nhập (Messenger inbox). Lúc GỬI, bot mở thẳng link FB của từng khách.
FACEBOOK_CHAT_URL=https://www.facebook.com/messages/

# ---------- CHẾ ĐỘ TEST AN TOÀN ----------
# Đây chỉ là GIÁ TRỊ MẶC ĐỊNH ban đầu. Có thể chỉnh trực tiếp trên UI (Cài đặt → Chế độ),
# thay đổi lưu vào config/test-mode.json và có hiệu lực NGAY, không cần sửa file này + restart.
# true = CHỈ gửi tới các số trong TEST_PHONES; mọi số khác bị chặn (không gửi tới khách thật)
TEST_MODE=true
# Danh sách số được phép gửi khi TEST_MODE=true (cách nhau dấu phẩy)
TEST_PHONES=0900000000
