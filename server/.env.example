# ============================================================
#  DORAEMI BOT — SERVER (.env cho phần chạy trên ai.basso.vn)
#  Chỉ liệt kê các biến NÊN có giá trị. Các biến tùy chọn (vốn để trống
#  để TẮT tính năng) KHÔNG liệt kê ở đây — code tự dùng mặc định an toàn.
#  Xem mục "TÙY CHỌN (thêm khi cần)" ở cuối file.
# ============================================================

# ---------- BẮT BUỘC ----------
# Khóa bí mật server <-> local-runner. ĐỔI thành chuỗi ngẫu nhiên dài, GIỐNG NHAU 2 nơi.
API_KEY=doi-thanh-chuoi-ngau-nhien-dai
# true = bắt buộc có API_KEY mới chạy (production nên bật).
REQUIRE_API_KEY=true

# ---------- CỔNG (nền tảng tự cấp PORT, biến này chỉ là fallback) ----------
SERVER_PORT=8080

# ---------- LƯU TRỮ DỮ LIỆU (SQLite: lịch sử báo + chống gửi trùng) ----------
# Thư mục chứa db (db = <DATA_DIR>/doraemi.sqlite). Để chạy thật BỀN, trỏ vào volume
# nền tảng cấp (vd /data). ./data chỉ bền nếu thư mục app nằm trên ổ ghi-bền.
DATA_DIR=./data

# ---------- CORS / ĐĂNG KÝ RUNNER ----------
# Origin được phép gọi API (gateway ai.basso.vn).
CORS_ORIGIN=https://ai.basso.vn
# Host được phép đăng ký runner qua /api/register-local (hỗ trợ *.domain).
REGISTER_ALLOWED_HOSTS=*.trycloudflare.com
# Fallback URL local-runner khi runner chưa tự đăng ký (chạy chung máy). Dùng start.js thì không cần.
PLAYWRIGHT_LOCAL_URL=http://localhost:8090

# ---------- API BASSO ----------
# true = chạy bằng dữ liệu MOCK (server/mock/orders.json) để test giao diện.
# false = gọi Partner API thật -> PHẢI điền đúng 4 biến BASSO_* ngay dưới.
USE_MOCK=true
# URL gốc Partner API do Basso cấp. BẮT BUỘC có https:// ở đầu (vd https://api.basso.vn).
BASSO_API_BASE_URL=https://api.basso.vn
# Key đối tác Basso cấp (gửi trong header X-Partner-Api-Key). Thay bằng key thật.
BASSO_API_KEY=DIEN-KEY-BASSO-CAP
# Tài khoản đăng nhập Partner API (POST /partner/login). Thay bằng email/mật khẩu thật.
BASSO_EMAIL=dien-email@basso.vn
BASSO_PASS=DIEN-MAT-KHAU
# Gửi Zalo xong tự cập nhật trạng thái "Đã báo hàng" về web Basso.
AUTO_UPDATE_STATUS=true
# Timeout (ms) mỗi request tới Basso. 0 = tắt.
BASSO_TIMEOUT_MS=25000
# TTL (ms) cache danh sách hàng về trong RAM. 0 = tắt.
BASSO_LIST_CACHE_TTL_MS=30000
# Chu kỳ (ms) nạp sẵn khung nhìn mặc định của dashboard vào cache RAM (giữ cache ấm). 0 = tắt.
BASSO_PRELOAD_INTERVAL_MS=60000
# Log thời gian từng call Basso (chẩn đoán chậm).
BASSO_LOG_TIMING=false

# ---------- TỰ ĐỘNG BÁO HÀNG ----------
# false = tắt lúc đầu cho an toàn (có thể bật/tắt ngay trên dashboard).
AUTO_NOTIFY=false
# Sau RESTART: false (mặc định) = tạm dừng, chờ admin bấm "Quét & gửi" mới gửi bù đợt còn dở;
# true = tự chạy lại ngay khi khởi động. (Chống trùng vẫn giữ: khách đã nhận không bị gửi lại.)
AUTO_NOTIFY_RESUME_ON_BOOT=false
# Chu kỳ quét (ms). Mặc định 60000 = 1 phút. Tối thiểu 10000.
AUTO_NOTIFY_INTERVAL_MS=60000
AUTO_NOTIFY_PROFILE=default
# Bot gửi xong có đẩy trạng thái về web Basso không (true mặc định).
AUTO_NOTIFY_UPDATE_WEB=true
# Số lần THỬ 1 đơn khi lỗi cấp-đơn (vd không tìm thấy hội thoại). Mặc định 1 = không thử lại (chốt
# 'failed' để tự kiểm tra). Lỗi tạm thời (runner offline/chưa đăng nhập) không tính vào đây.
AUTO_NOTIFY_MAX_RETRIES=1
# CHỈ tự báo đơn về TỪ khi account được bật "Tự động báo" (bỏ qua tồn đọng cũ) -> chống nhắn
# trùng loạt khách cũ khi bật lại auto cho 1 NV. false = gửi cả tồn đọng như trước.
AUTO_NOTIFY_ONLY_NEW=true
# true = CHỈ tự gửi đơn khớp đúng 1 tài khoản Zalo đang BẬT auto; đơn không khớp account nào
# (rơi về mặc định) hoặc account tắt auto -> bỏ qua. Dùng để cô lập test về 1 NV: bật auto cho
# 1 account là chỉ NV đó được gửi. false (mặc định) = đơn không khớp vẫn gửi bằng account mặc định.
AUTO_NOTIFY_REQUIRE_ACCOUNT=false
# WEBHOOK REALTIME: điền 1 chuỗi bí mật để Basso gọi POST /api/webhook/arrived (kèm header
# x-webhook-secret khớp) -> có hàng về là gửi NGAY (đọc tươi bỏ cache), nhanh hơn poller.
# ĐỂ TRỐNG = webhook KHÔNG kiểm tra secret (ai gọi URL cũng kích hoạt quét). Không dùng webhook
# thì cứ để trống — poller vẫn chạy bình thường.
AUTO_NOTIFY_WEBHOOK_SECRET=

# ============================================================
#  TÙY CHỌN — chỉ THÊM dòng tương ứng khi thực sự cần.
#  KHÔNG để trống các biến này: nếu không dùng thì ĐỪNG thêm chúng vào .env.
# ============================================================
#  GATEWAY_SECRET=<bí mật>   # CHỈ thêm khi gateway ai.basso.vn ĐÃ gắn header
#                            # X-Gateway-Secret. Thêm khi gateway chưa gắn = CHẶN HẾT (401).
#  AUTH_USER_HEADER=...      # Đổi danh sách header nhận diện NV (trống = mặc định).
#  BASSO_AUTH_URL=...        # Endpoint xác minh phiên Basso cho phân quyền (pattern Xeko).
#                            # Mặc định https://ai.basso.vn/platform/api/auth/session — khi gateway
#                            # KHÔNG forward header x-user-email, app gửi cookie sang đây hỏi "ai đây".
#  ZALO_ACCOUNT_MAP={...}    # Map NV->Zalo kiểu cũ. Giờ khai qua dashboard, không cần.
#  AUTO_NOTIFY_ACCOUNT=...   # Tài khoản Zalo mặc định cho gửi tự động.
#  DB_PATH=/data/doraemi.sqlite    # Đường dẫn file db đầy đủ (ưu tiên hơn DATA_DIR).
