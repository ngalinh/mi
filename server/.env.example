# ============================================================
#  DORAEMI BOT — SERVER (.env cho phần chạy trên ai.basso.vn)
#  Chỉ gồm biến mà server/ thực sự dùng (xem server/config.js).
#  Các biến của LOCAL-RUNNER (Playwright/Zalo/SALEWORK_*/HEADLESS...)
#  nằm ở .env.example gốc — máy local-runner mới cần.
# ============================================================

# ---------- BẮT BUỘC ----------
# Khóa bí mật server <-> local-runner (đặt CHUỖI NGẪU NHIÊN DÀI, giống nhau 2 nơi).
API_KEY=doi-thanh-chuoi-ngau-nhien-dai
# true = bắt buộc có API_KEY mới chạy (production nên bật). Để trống = dev vẫn chạy.
REQUIRE_API_KEY=true

# ---------- CỔNG ----------
# Nền tảng ai.basso.vn tự cấp qua biến PORT — server ưu tiên PORT, không có mới dùng SERVER_PORT.
SERVER_PORT=8080

# ---------- LƯU TRỮ BỀN (SQLite: lịch sử báo + khóa chống gửi trùng) ----------
# Container cloud là ephemeral — restart là mất. Trỏ vào ổ/volume BỀN nếu có.
#   DATA_DIR : thư mục data (db = <DATA_DIR>/doraemi.sqlite). Vd /data
#   DB_PATH  : (ưu tiên) đường dẫn file db đầy đủ. Vd /data/doraemi.sqlite
# Để trống cả hai = dùng ./data trong app (chỉ bền nếu ./data nằm trên volume).
DATA_DIR=
DB_PATH=

# ---------- GATEWAY / BẢO MẬT (tùy chọn) ----------
# Danh tính nhân viên do gateway ai.basso.vn forward qua header (để ghi "ai gửi tin").
# Để trống = dùng mặc định (x-user-email,x-forwarded-email,...).
AUTH_USER_HEADER=
# Origin được phép (cách nhau dấu phẩy). Để trống = mở mọi origin.
CORS_ORIGIN=https://ai.basso.vn
# Nếu đặt, mọi /api/* phải kèm header X-Gateway-Secret khớp. Để trống = bỏ qua.
GATEWAY_SECRET=
# Allowlist host được đăng ký qua /api/register-local (hỗ trợ *.domain). Để trống = cho tất cả.
REGISTER_ALLOWED_HOSTS=*.trycloudflare.com
# Fallback URL local-runner khi runner chưa tự đăng ký (dùng start.js thì không cần).
PLAYWRIGHT_LOCAL_URL=http://localhost:8090

# ---------- API BASSO (Partner API) ----------
# Để trống BASE_URL (+ USE_MOCK=true) => chạy bằng dữ liệu MOCK trong server/mock/orders.json.
# Chạy thật: điền https://api.basso.vn + key/email/pass và đặt USE_MOCK=false.
BASSO_API_BASE_URL=
BASSO_API_KEY=
BASSO_EMAIL=
BASSO_PASS=
USE_MOCK=true
# Gửi Zalo xong tự cập nhật trạng thái "Đã báo hàng" ngược về web Basso.
AUTO_UPDATE_STATUS=true
# Timeout (ms) mỗi request tới Basso. 0 = tắt.
BASSO_TIMEOUT_MS=12000
# TTL (ms) cache danh sách hàng về trong RAM. 0 = tắt.
BASSO_LIST_CACHE_TTL_MS=30000
# Log thời gian từng call Basso để chẩn đoán chậm.
BASSO_LOG_TIMING=false

# ---------- ÁNH XẠ ZALO THEO NHÂN VIÊN (tùy chọn) ----------
# JSON: key = user_id NV hoặc tên NV, value = tên account Zalo. Vd {"18":"Zalo Linh"}.
ZALO_ACCOUNT_MAP=

# ---------- TỰ ĐỘNG BÁO HÀNG ----------
# true = server tự quét đơn "Chưa báo" và gửi. Có thể bật/tắt trên dashboard.
AUTO_NOTIFY=false
AUTO_NOTIFY_INTERVAL_MS=120000
AUTO_NOTIFY_PROFILE=default
# (Tùy chọn) tên account Zalo cần chọn trước khi gửi tự động.
AUTO_NOTIFY_ACCOUNT=
# Bot gửi xong có đẩy trạng thái về web Basso không (true mặc định).
AUTO_NOTIFY_UPDATE_WEB=true
AUTO_NOTIFY_MAX_RETRIES=3
# (Tùy chọn) bí mật bảo vệ webhook /api/webhook/arrived. Để trống = không kiểm tra.
AUTO_NOTIFY_WEBHOOK_SECRET=
